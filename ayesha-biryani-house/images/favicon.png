<svg viewBox="0 0 200 240" xmlns="http://www.w3.org/2000/svg" width="200" height="240">
  <!-- Shield background -->
  <path d="M 50 40 Q 50 20 100 20 Q 150 20 150 40 L 150 120 Q 150 180 100 220 Q 50 180 50 120 Z" fill="none" stroke="#000000" stroke-width="16" stroke-linejoin="round"/>

  <!-- Orange flame -->
  <g transform="translate(100, 50)">
    <path d="M 0 -18 Q -10 -6 -8 6 Q -5 16 0 18 Q 5 16 8 6 Q 10 -6 0 -18 Z" fill="#FF9800"/>
    <path d="M -5 -10 Q -9 -2 -6 6 Q -3 10 0 10 Q -3 7 -5 -10 Z" fill="#FFB74D"/>
    <path d="M 5 -10 Q 9 -2 6 6 Q 3 10 0 10 Q 3 7 5 -10 Z" fill="#FFB74D"/>
  </g>

  <!-- Rooster body -->
  <g transform="translate(100, 105)">
    <!-- Body -->
    <ellipse cx="0" cy="0" rx="20" ry="26" fill="#000000"/>
    <!-- Neck -->
    <rect x="-10" y="-24" width="20" height="22" fill="#000000"/>
    <!-- Head -->
    <circle cx="0" cy="-38" r="12" fill="#000000"/>
    <!-- Comb -->
    <path d="M -8 -46 Q -11 -54 -5 -58 Q 0 -60 5 -58 Q 11 -54 8 -46" fill="#000000"/>
    <!-- Beak -->
    <polygon points="10,-38 20,-36 12,-32" fill="#000000"/>
    <!-- Eye -->
    <circle cx="4" cy="-40" r="3" fill="#FFFFFF"/>
    <!-- Tail feathers -->
    <path d="M -18 -8 Q -32 -20 -28 -8" stroke="#000000" stroke-width="4" fill="none" stroke-linecap="round"/>
    <path d="M -19 0 Q -34 -12 -30 0" stroke="#000000" stroke-width="4" fill="none" stroke-linecap="round"/>
    <path d="M -18 8 Q -32 -4 -27 8" stroke="#000000" stroke-width="4" fill="none" stroke-linecap="round"/>
    <!-- Legs -->
    <rect x="-6" y="22" width="3" height="14" fill="#000000"/>
    <rect x="3" y="22" width="3" height="14" fill="#000000"/>
  </g>
</svg>